# ===== novel_workflow 环境变量模板 =====
# 复制为 .env 然后填实际值, .env 已加入 .gitignore

# === LLM (本地 llama-server, 默认不动) ===
LLM_API_BASE=http://127.0.0.1:60443/v1
LLM_DEFAULT_MODEL=Qwen3.6-35B-A3B-UD-Q4_K_M.gguf
LLM_TIMEOUT_SEC=600
LLM_MAX_RETRIES=3

# === review_ui 公网认证 (Basic Auth) ===
# Username 用于 HTTP Basic Auth, 必须设
REVIEW_UI_USER=weichao
# Password 用强随机密码, 推荐 `openssl rand -base64 24`
REVIEW_UI_PASSWORD=change-me-immediately

# === 备份 ===
BACKUP_RETENTION_DAYS=7
BACKUP_TIME=03:00

# === 日志 ===
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/novel_workflow.log
LOG_ROTATION=10MB x 5
